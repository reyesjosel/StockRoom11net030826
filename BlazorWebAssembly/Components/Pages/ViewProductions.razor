@page "/ViewProductions"
@using StockRoom11net.BlazorWebAssembly
@using StockRoom11net.BlazorWebAssembly.Components
@using StockRoom11net.BlazorWebAssembly.Components.Pages
@using StockRoom11net.BlazorWebAssembly.Data
@inject AppState AppState

<body>
    <style type="text/css">
        *:focus {
            outline: 0;
        }

        ul.fancytree-container {
            font-family: Times New Roman;
            font-size: 16pt;
            border: none;
        }

        div {
            display: block;
        }

        #wrapper {
            width: 100%;
            height: auto;
        }

        #tree {
            float: left;
            width: 50%;
        }

        #second {
            float: left;
            width: 50%;
            margin-top: 10px;
        }

        .spanPasive {
            font-size: 14pt;
            color: darkgray;
        }

        .spanActive {
            font-size: 24pt;
            color: black;
        }

        table {
            width: 100%;
            border-spacing: 0;
            font-size: 18px;
            margin: auto;
            border: #ccc 1px solid;
            border-radius: 10px;
            table-layout: fixed;
        }

            table th {
                text-align: left;
                font-weight: bold;
                padding-left: 10px;
                padding: 10px;
                border: 1px solid #e0e0e0;
                background: #d5d5d5;
            }

            table tr:first-child th:first-child {
                border-top-left-radius: 10px;
            }

            table tr:first-child th:last-child {
                text-align: center;
                border-top-right-radius: 10px;
            }

            table tr:last-child td:first-child {
                border-bottom-left-radius: 10px;
            }

            table tr:last-child td:last-child {
                border-bottom-right-radius: 10px;
            }

            table tr td:first-child {
                text-align: left;
            }

            table tr td {
                padding-left: 10px;
                border-top: 1px solid #e0e0e0;
                border-left: 1px solid #e0e0e0;
            }

                table tr td:last-child {
                    padding-left: 0px;
                    text-align: center;
                    border-left: 1px solid #e0e0e0;
                }

            table tr:nth-child(odd) td {
                background: #e6e6e6;
            }

            table tr:last-child td {
                border-bottom: 0;
            }

            table tr:hover td {
                background: #d5d5d5;
            }

        tr.selected {
            background-color: #FFCF8B
        }
    </style>
    <script type="text/javascript">
        if (window.location.hash.substr(1, 2) == "zx") {
            var bc = window.location.hash.substr(3);
            localStorage["barcode"] = decodeURI(window.location.hash.substr(3))
            window.close();
            self.close();
            window.location.href = "about:blank";//In case self.close isn't allowed
        }
    </script>
    <script type="text/javascript" id="jsPro">
        var node;
        var textSearch = '';
        var uri = 'api/productions';
        var optiSearch = '';
        $(document).ready(function () {
            $(function () {
                $("#tree").fancytree(
                    {
                        extensions: ["wide"],
                        autoCollapse: true,
                        clickFolderMode: 3,
                        focusOnSelect: true,
                        source: { url: 'api/treeSource?' + window.myhref},
                        activate: function (event, data) {
                            node = data.node;
                            $('#products tbody > tr').remove();
                            $.getJSON(uri + '/' + "Filter:" + node.key)
                                .done(function (data) { tableFill(data); })
                                .fail(function (jqXHR, textStatus, err) {
                                    $('#Answer').text('The filter data fault...' + err);
                                });
                        }
                    });
            });

            $.getJSON(uri)
                .done(function (data) { tableFill(data) })
                .fail(function (jqXHR, textStatus, err) {
                    $('#st').text('error' + err);
                });

            $("#SearchText").keyup(function (e) {
                textSearch = $('#SearchText').val();
                if (event.key === "Enter") {
                    $("#SearchText").blur();
                    find();
                }
                else {
                    if (e.keyCode === 8 && textSearch.length === 0) {
                        $("#SearchText").blur();
                        $("#spanPasive[class='spanActive']").toggleClass("spanPasive spanActive");
                        $("#spanActive[class='spanPasive']").toggleClass("spanActive spanPasive");
                    }
                    else {
                        $('#Answer').text("");
                        $("#spanPasive[class='spanPasive']").toggleClass("spanPasive spanActive");
                        $("#spanActive[class='spanActive']").toggleClass("spanActive spanPasive");
                    }
                }
                event.stopPropagation();
            });

            //history.pushState({}, "", "http://smsprod.ngrok.io/Productions");
        });

        function find() {
            if (node != null) {
                node.setFocus(false);
                node.setActive(false);
            }

            textSearch = $('#SearchText').val();
            optiSearch = $('#SearchOption option:selected').text();
            if (textSearch.length === 0)
                getScan();
            else
            {
                $('#Answer').text("");
                $('#products tbody > tr').remove();
                $.getJSON(uri + '/' + optiSearch + ":" + textSearch)
                    .done(function (data) { tableFill(data); })
                    .fail(function (jqXHR, textStatus, err) {
                        $('#Answer').text('error' + err);
                    });
            }
        };

        function tableFill(data) {
            $.each(data, function (key, item) {
                $('#products tbody').append("<tr><td>" + item.PartNumber + "</td>" + "<td>" + item.Description + "</td>" + "<td>" + item.OnHand + "</td></tr>");

            })
            $('#Answer').text("Found " + $('#products >tbody >tr').length + " products.");
            $("tr").click(function () {
                $(this).addClass("selected").siblings().removeClass("selected");
            });
        };

        //BarCode Events...
        var changingHash = false;
        function onbarcode(event) {
            switch (event.type) {
                case "hashchange": {
                    if (changingHash == true) { return; }
                    var hash = window.location.hash;
                    if (hash.substr(0, 3) == "#zx") {
                        hash = window.location.hash.substr(3);
                        changingHash = true;
                        window.location.hash = event.oldURL.split("\#")[1] || ""
                        changingHash = false;
                        $('#SearchText').val(hash);
                        find();
                    }

                    break;
                }
                case "storage": {
                    window.focus();
                    if (event.key == "barcode") {
                        window.removeEventListener("storage", onbarcode, false);
                        $('#SearchText').val(event.newValue);
                        find();
                    }
                    break;
                }
                default: {
                    console.log(event)
                    break;
                }
            }
        }
        window.addEventListener("hashchange", onbarcode, false);

        function getScan() {
            var href = window.location.href;
            var ptr = href.lastIndexOf("#");
            if (ptr > 0) { href = href.substr(0, ptr); }
            window.addEventListener("storage", onbarcode, false);
            setTimeout('window.removeEventListener("storage", onbarcode, false)', 15000);
            localStorage.removeItem("barcode");
            //window.open  (href + "#zx" + new Date().toString());

            if (navigator.userAgent.match(/Firefox/i)) { window.location.href = ("zxing://scan/?ret=" + encodeURIComponent(href + "#zx{CODE}")); }
            else { window.open("zxing://scan/?ret=" + encodeURIComponent(href + "#zx{CODE}")); }
        }
    </script>

    <div id="wrapper">
        <div id="tree"></div>
        <div id="second">
            <div id="SearchOptions" style="float:left; height:40px; width:75%; font-size:22pt;">
                <label for="Search" style="font-size:22pt;">Search by </label>
                <select id="SearchOption" name="Search" required style="font-family:Times New Roman; font-size:22pt; border:none">
                    <option value="PartNumber">PartNumber</option>
                    <option value="Description">Description</option>
                </select>
            </div>
            <div style="float:left; height:80px; width:75%; margin-top:5px">
                <input type="text" id="SearchText" size="1" aria-label="Search" style="font-size:22pt;width:95%;" />
                <p id="Answer" style="font-size:12pt; margin-top:5px;" draggable="false"></p>
            </div>

            <button style="width:25%; height:90px; border-radius: 10px;" onclick="find();">
                <span id="spanPasive" class="spanPasive">Search<br /></span>
                <span id="spanActive" class="spanActive">Scan</span>
            </button>
        </div>
    </div>
    <div style="float:left;">
        <table id="products">
            <thead>
                <tr>
                    <th style="width:25%">PartNumber</th>
                    <th style="width:65%">Description</th>
                    <th style="width:10%">OnHand</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
</body>









@code {
    private int currentCount = 0;

    protected override void OnInitialized()
    {
        //message = $"Initialized at {DateTime.Now}";
    }

    protected override void OnParametersSet()
    {
        currentCount = AppState.Counter;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        //Do not update the view. AfterRender...
        currentCount = AppState.Counter;
    }

    private void IncrementCount()
    {
        currentCount++;
        AppState.Counter++;
    }
}

    /// <summary>
    /// Event called on mouse down
    /// </summary>
    [Parameter]
    [DesignerSerializationVisibility(DesignerSerializationVisibility.Hidden)]
    public EventCallback<CanvasMouseArgs> MouseDown { get; set; }

    /// <summary>
    /// Event called on mouse up
    /// </summary>

    /// <summary>
    /// Call this in your Blazor app's OnAfterRenderAsync method when firstRender is true
    /// </summary>
    /// <returns></returns>
    public async Task Initialize()
    {
        string jsonString = "";

        try
        {
            // We need to specify the .js file path relative to this code
            _moduleTask = new(() => _jsRuntime.InvokeAsync<IJSObjectReference>(
            "import", "./Jscript/TimeLineHelper.js").AsTask());

            // Load the module
            var module = await _moduleTask.Value;

            // Initialize
            await module.InvokeVoidAsync("startTimeLine", DotNetObjectReference.Create(this));

            // Dispose the module
            //    await module.DisposeAsync();
        }
        catch (Exception ex)
        {
            string message = ex.Message;
        }
    }

